{
  "name": "@averay/codeformat",
  "version": "0.3.0",
  "description": "A very opinionated collection of configurations for a number of code formatting tools.",
  "homepage": "https://github.com/adamaveray/codeformat",
  "author": "Adam Averay (https://adamaveray.com.au/)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adamaveray/codeformat.git"
  },
  "bin": {
    "codeformat": "dist/bin/codeformat.js"
  },
  "files": [
    "/.editorconfig",
    "/dist",
    "/README.md",
    "/tsconfig.base.json",
    "/types.d.ts"
  ],
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "rm -rf dist && bun run build:tsc && chmod +x dist/bin/*.js",
    "build:tsc": "bun --bun x tsc --project tsconfig.build.json --outDir dist",
    "test": "bun test",
    "format": "bun run build && dist/bin/codeformat.js fix",
    "lint": "bun run build && dist/bin/codeformat.js check",
    "prepare": "bun --bun x husky",
    "prepack": "bun run build",
    "release": "bun run lint && bun --bun x bumpp && bun publish --access=public",
    "watch": "bun run build:tsc --watch"
  },
  "dependencies": {
    "@averay/css-properties-sort-order": "^1.0.3",
    "globals": "^17.4.0",
    "postcss-scss": "^4.0.9",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-config-recommended-scss": "^17.0.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-plugin-defensive-css": "^2.8.0",
    "stylelint-scss": "^7.0.0",
    "stylelint-use-logical": "^2.1.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "bumpp": "^11.0.1",
    "husky": "^9.1.7",
    "knip": "^6.0.4",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.3",
    "stylelint": "^17.5.0",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "knip": "^6.0.4",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.1",
    "stylelint": "^17.4.0"
  },
  "engines": {
    "bun": ">=1.3"
  },
  "licence": "MIT"
}
